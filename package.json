{
  "name": "triage-companion",
  "version": "1.0.0",
  "description": "Terminal tool for developer productivity - GitHub, Snyk, Jira, and Git status in one place.",
  "type": "module",
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md",
    "AGENTS.md",
    "tsconfig.json"
  ],
  "bin": {
    "triage-companion": "./src/index.ts"
  },
  "scripts": {
    "start": "node src/index.ts",
    "test": "node --test --test-concurrency=1 src/*.test.ts src/**/*.test.ts",
    "lint": "eslint --flag unstable_native_nodejs_ts_config -c eslint.config.ts \"src/**/*.ts\"",
    "check:file-lines": "node src/check-file-lines.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3"
  }
}
